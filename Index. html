<!DOCTYPE html>
<html lang="zh">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>DataAI · Excel 智能分析工具</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Noto+Sans+SC:wght@400;500;700;900&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #f7f3ed;
  --dark: #0e0e0e;
  --red: #e8320a;
  --yellow: #f5c800;
  --white: #ffffff;
  --muted: #8a8070;
  --border: #d8d0c4;
}

* { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }

body {
  background: var(--bg);
  color: var(--dark);
  font-family: 'Noto Sans SC', sans-serif;
  overflow-x: hidden;
}

/* NAV */
nav {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 100;
  background: var(--bg);
  border-bottom: 2px solid var(--dark);
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 40px;
  height: 60px;
}

.nav-logo {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 24px;
  letter-spacing: 0.08em;
  color: var(--dark);
}

.nav-logo span { color: var(--red); }

.nav-links {
  display: flex;
  gap: 32px;
  list-style: none;
}

.nav-links a {
  font-family: 'JetBrains Mono', monospace;
  font-size: 12px;
  color: var(--muted);
  text-decoration: none;
  letter-spacing: 0.05em;
  transition: color 0.15s;
}

.nav-links a:hover { color: var(--dark); }

.nav-cta {
  background: var(--dark);
  color: var(--bg) !important;
  padding: 8px 20px;
  font-weight: 500 !important;
}

.nav-cta:hover { background: var(--red); color: var(--white) !important; }

/* HERO */
.hero {
  min-height: 100vh;
  display: flex;
  align-items: center;
  padding: 100px 40px 60px;
  position: relative;
  overflow: hidden;
}

.hero-bg-text {
  position: absolute;
  font-family: 'Bebas Neue', sans-serif;
  font-size: 28vw;
  color: rgba(0,0,0,0.04);
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  white-space: nowrap;
  pointer-events: none;
  letter-spacing: -0.02em;
}

.hero-inner {
  max-width: 1100px;
  margin: 0 auto;
  width: 100%;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 60px;
  align-items: center;
  position: relative;
  z-index: 1;
}

.hero-tag {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px;
  color: var(--red);
  border: 1.5px solid var(--red);
  padding: 5px 14px;
  margin-bottom: 24px;
  animation: slideIn 0.6s ease both;
}

.hero-tag::before {
  content: '';
  width: 6px; height: 6px;
  background: var(--red);
  border-radius: 50%;
  animation: pulse 1.5s infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.3; }
}

@keyframes slideIn {
  from { opacity: 0; transform: translateY(20px); }
  to { opacity: 1; transform: translateY(0); }
}

.hero h1 {
  font-family: 'Bebas Neue', sans-serif;
  font-size: clamp(56px, 7vw, 96px);
  line-height: 0.95;
  letter-spacing: 0.02em;
  margin-bottom: 24px;
  animation: slideIn 0.6s 0.1s ease both;
}

.hero h1 .line2 {
  color: var(--red);
  display: block;
}

.hero h1 .line3 {
  color: var(--dark);
  display: block;
  -webkit-text-stroke: 2px var(--dark);
  color: transparent;
}

.hero-desc {
  font-size: 16px;
  line-height: 1.8;
  color: #444;
  margin-bottom: 36px;
  animation: slideIn 0.6s 0.2s ease both;
}

.hero-btns {
  display: flex;
  gap: 16px;
  flex-wrap: wrap;
  animation: slideIn 0.6s 0.3s ease both;
}

.btn {
  font-family: 'Noto Sans SC', sans-serif;
  font-weight: 700;
  font-size: 14px;
  padding: 14px 32px;
  border: 2px solid var(--dark);
  cursor: pointer;
  text-decoration: none;
  display: inline-flex;
  align-items: center;
  gap: 8px;
  transition: all 0.15s;
}

.btn-primary {
  background: var(--dark);
  color: var(--bg);
}

.btn-primary:hover {
  background: var(--red);
  border-color: var(--red);
  transform: translate(-2px, -2px);
  box-shadow: 4px 4px 0 var(--dark);
}

.btn-outline {
  background: transparent;
  color: var(--dark);
}

.btn-outline:hover {
  transform: translate(-2px, -2px);
  box-shadow: 4px 4px 0 var(--dark);
}

.hero-visual {
  animation: slideIn 0.6s 0.4s ease both;
}

.mock-tool {
  background: var(--dark);
  border: 2px solid var(--dark);
  overflow: hidden;
  box-shadow: 8px 8px 0 var(--red);
}

.mock-bar {
  background: #1a1a1a;
  padding: 10px 16px;
  display: flex;
  align-items: center;
  gap: 6px;
  border-bottom: 1px solid #2a2a2a;
}

.mock-dot {
  width: 10px; height: 10px;
  border-radius: 50%;
}

.mock-title {
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px;
  color: #555;
  margin-left: 8px;
}

.mock-content {
  padding: 24px;
}

.mock-upload {
  border: 1.5px dashed #333;
  padding: 24px;
  text-align: center;
  margin-bottom: 16px;
}

.mock-upload-icon { font-size: 28px; margin-bottom: 8px; }

.mock-upload p {
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px;
  color: #555;
}

.mock-stats {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 8px;
  margin-bottom: 16px;
}

.mock-stat {
  background: #1a1a1a;
  padding: 12px;
  text-align: center;
}

.mock-stat-val {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 24px;
  color: #00ff88;
}

.mock-stat-label {
  font-family: 'JetBrains Mono', monospace;
  font-size: 9px;
  color: #444;
}

.mock-result {
  background: #1a1a1a;
  border-left: 3px solid #0088ff;
  padding: 14px;
}

.mock-result p {
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px;
  color: #aaa;
  line-height: 1.7;
}

.mock-result p strong { color: #00ff88; }

/* MARQUEE */
.marquee-wrap {
  overflow: hidden;
  background: var(--dark);
  border-top: 2px solid var(--dark);
  border-bottom: 2px solid var(--dark);
  padding: 14px 0;
}

.marquee-track {
  display: flex;
  gap: 60px;
  animation: marquee 20s linear infinite;
  white-space: nowrap;
}

.marquee-item {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 18px;
  letter-spacing: 0.1em;
  color: var(--bg);
  flex-shrink: 0;
}

.marquee-item span { color: var(--red); }

@keyframes marquee {
  from { transform: translateX(0); }
  to { transform: translateX(-50%); }
}

/* SECTIONS */
section { padding: 80px 40px; }

.section-inner { max-width: 1100px; margin: 0 auto; }

.section-label {
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px;
  color: var(--red);
  letter-spacing: 0.12em;
  text-transform: uppercase;
  margin-bottom: 16px;
}

.section-title {
  font-family: 'Bebas Neue', sans-serif;
  font-size: clamp(36px, 5vw, 60px);
  line-height: 1;
  margin-bottom: 16px;
}

.section-sub {
  font-size: 15px;
  color: #555;
  line-height: 1.7;
  max-width: 560px;
}

/* HOW IT WORKS */
.steps {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 2px;
  margin-top: 48px;
  border: 2px solid var(--dark);
}

.step {
  padding: 36px 28px;
  border-right: 2px solid var(--dark);
  position: relative;
  background: var(--white);
  transition: background 0.2s;
}

.step:last-child { border-right: none; }
.step:hover { background: var(--yellow); }

.step-num {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 72px;
  line-height: 1;
  color: rgba(0,0,0,0.08);
  position: absolute;
  top: 16px; right: 20px;
}

.step-icon { font-size: 36px; margin-bottom: 16px; }

.step h3 {
  font-size: 18px;
  font-weight: 700;
  margin-bottom: 10px;
}

.step p {
  font-size: 14px;
  color: #555;
  line-height: 1.7;
}

/* FEATURES */
.features-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 2px;
  margin-top: 48px;
  border: 2px solid var(--dark);
}

.feature {
  padding: 32px;
  background: var(--white);
  border-right: 2px solid var(--dark);
  border-bottom: 2px solid var(--dark);
  transition: all 0.2s;
}

.feature:nth-child(2n) { border-right: none; }
.feature:nth-last-child(-n+2) { border-bottom: none; }
.feature:hover { background: var(--dark); color: var(--bg); }
.feature:hover p { color: #aaa; }

.feature-icon { font-size: 32px; margin-bottom: 16px; }

.feature h3 {
  font-size: 17px;
  font-weight: 700;
  margin-bottom: 8px;
}

.feature p { font-size: 13px; color: #666; line-height: 1.7; }

/* PRICING */
#pricing { background: var(--dark); }

#pricing .section-label { color: var(--yellow); }
#pricing .section-title { color: var(--bg); }
#pricing .section-sub { color: #666; }

.pricing-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 2px;
  margin-top: 48px;
  border: 2px solid #333;
}

.price-card {
  padding: 36px 28px;
  background: #111;
  border-right: 2px solid #333;
  position: relative;
  transition: background 0.2s;
}

.price-card:last-child { border-right: none; }

.price-card.featured {
  background: var(--red);
}

.price-card:not(.featured):hover { background: #1a1a1a; }

.price-label {
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px;
  color: #555;
  letter-spacing: 0.08em;
  margin-bottom: 16px;
}

.price-card.featured .price-label { color: rgba(255,255,255,0.7); }

.price-amount {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 56px;
  line-height: 1;
  color: var(--bg);
  margin-bottom: 4px;
}

.price-unit {
  font-family: 'JetBrains Mono', monospace;
  font-size: 12px;
  color: #555;
  margin-bottom: 24px;
}

.price-card.featured .price-unit { color: rgba(255,255,255,0.6); }

.price-features {
  list-style: none;
  margin-bottom: 32px;
}

.price-features li {
  font-size: 13px;
  color: #888;
  padding: 6px 0;
  border-bottom: 1px solid #222;
  display: flex;
  align-items: center;
  gap: 8px;
}

.price-card.featured .price-features li {
  color: rgba(255,255,255,0.85);
  border-bottom-color: rgba(255,255,255,0.15);
}

.price-features li::before {
  content: '✓';
  color: var(--yellow);
  font-weight: 700;
  font-size: 12px;
}

.price-card.featured .price-features li::before { color: #fff; }

.btn-price {
  width: 100%;
  justify-content: center;
  font-size: 13px;
  padding: 12px;
}

.price-card:not(.featured) .btn-price {
  border-color: #333;
  color: var(--bg);
  background: transparent;
}

.price-card:not(.featured) .btn-price:hover {
  background: var(--bg);
  color: var(--dark);
  box-shadow: none;
  transform: none;
}

.price-card.featured .btn-price {
  background: var(--dark);
  color: var(--bg);
  border-color: var(--dark);
}

/* TESTIMONIALS */
.testimonials {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24px;
  margin-top: 48px;
}

.testi {
  background: var(--white);
  border: 2px solid var(--dark);
  padding: 28px;
  position: relative;
}

.testi::before {
  content: '"';
  font-family: 'Bebas Neue', sans-serif;
  font-size: 80px;
  color: var(--red);
  line-height: 0.8;
  display: block;
  margin-bottom: 12px;
}

.testi p {
  font-size: 14px;
  line-height: 1.7;
  color: #333;
  margin-bottom: 20px;
}

.testi-author {
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px;
  color: var(--muted);
}

.testi-author strong {
  color: var(--dark);
  font-weight: 700;
  display: block;
  margin-bottom: 2px;
}

/* CTA */
#cta {
  background: var(--red);
  text-align: center;
}

#cta .section-title { color: var(--white); }
#cta .section-sub { color: rgba(255,255,255,0.75); margin: 0 auto 36px; }

.cta-btns {
  display: flex;
  gap: 16px;
  justify-content: center;
  flex-wrap: wrap;
}

#cta .btn-primary {
  background: var(--white);
  color: var(--red);
  border-color: var(--white);
}

#cta .btn-primary:hover {
  background: var(--dark);
  color: var(--white);
  border-color: var(--dark);
  box-shadow: 4px 4px 0 rgba(0,0,0,0.3);
}

#cta .btn-outline {
  border-color: rgba(255,255,255,0.5);
  color: var(--white);
}

#cta .btn-outline:hover {
  border-color: var(--white);
  box-shadow: 4px 4px 0 rgba(0,0,0,0.2);
}

/* CONTACT */
#contact { background: var(--dark); }
#contact .section-title { color: var(--bg); }

.contact-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 48px;
  margin-top: 48px;
  align-items: start;
}

.contact-info p {
  font-size: 15px;
  color: #666;
  line-height: 1.8;
  margin-bottom: 32px;
}

.contact-channels {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.channel {
  display: flex;
  align-items: center;
  gap: 14px;
  padding: 14px 18px;
  border: 1px solid #222;
  background: #111;
  transition: border-color 0.15s;
}

.channel:hover { border-color: #444; }

.channel-icon { font-size: 20px; }

.channel-info { flex: 1; }

.channel-name {
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px;
  color: #444;
  letter-spacing: 0.06em;
}

.channel-val {
  font-size: 14px;
  font-weight: 700;
  color: var(--bg);
  margin-top: 2px;
}

.contact-form {
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.form-group {
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.form-group label {
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px;
  color: #444;
  letter-spacing: 0.06em;
}

.form-group input,
.form-group textarea,
.form-group select {
  background: #111;
  border: 1px solid #222;
  color: var(--bg);
  padding: 12px 16px;
  font-family: 'Noto Sans SC', sans-serif;
  font-size: 14px;
  outline: none;
  transition: border-color 0.15s;
  resize: vertical;
}

.form-group input:focus,
.form-group textarea:focus,
.form-group select:focus { border-color: var(--red); }

.form-group select option { background: #111; }

.submit-btn {
  background: var(--red);
  color: var(--white);
  border: 2px solid var(--red);
  padding: 14px;
  font-family: 'Noto Sans SC', sans-serif;
  font-weight: 700;
  font-size: 15px;
  cursor: pointer;
  transition: all 0.15s;
  letter-spacing: 0.05em;
}

.submit-btn:hover {
  background: transparent;
  color: var(--red);
  transform: translate(-2px, -2px);
  box-shadow: 4px 4px 0 var(--red);
}

/* FOOTER */
footer {
  background: #070707;
  border-top: 2px solid #1a1a1a;
  padding: 24px 40px;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.footer-logo {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 20px;
  color: #333;
  letter-spacing: 0.08em;
}

.footer-logo span { color: var(--red); }

.footer-text {
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px;
  color: #333;
}

/* RESPONSIVE */
@media (max-width: 768px) {
  nav { padding: 0 20px; }
  .nav-links { display: none; }

  .hero { padding: 80px 20px 40px; }
  .hero-inner { grid-template-columns: 1fr; gap: 40px; }

  section { padding: 60px 20px; }

  .steps { grid-template-columns: 1fr; }
  .step { border-right: none; border-bottom: 2px solid var(--dark); }
  .step:last-child { border-bottom: none; }

  .features-grid { grid-template-columns: 1fr; }
  .feature { border-right: none; border-bottom: 2px solid var(--dark) !important; }

  .pricing-grid { grid-template-columns: 1fr; }
  .price-card { border-right: none; border-bottom: 2px solid #333; }

  .testimonials { grid-template-columns: 1fr; }

  .contact-grid { grid-template-columns: 1fr; }

  footer { flex-direction: column; gap: 12px; text-align: center; }
}

/* SCROLL ANIMATIONS */
.fade-up {
  opacity: 0;
  transform: translateY(30px);
  transition: opacity 0.6s ease, transform 0.6s ease;
}

.fade-up.visible {
  opacity: 1;
  transform: translateY(0);
}
</style>
</head>
